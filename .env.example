# ============================================================================
# OpenAB Software Team on EKS — Configuration
# Copy to .env and fill in your values:  cp .env.example .env
# ============================================================================

# --- AWS ---
AWS_REGION=us-east-1
CLUSTER_NAME=openab-team
NODE_INSTANCE_TYPE=t3.large
NODE_COUNT=2

# --- Discord ---
# Right-click channel → Copy Channel ID (enable Developer Mode first)
DISCORD_CHANNEL_ID=

# --- Kiro CLI ---
# Get your API key at https://kiro.dev
KIRO_API_KEY=

# --- GitHub (optional — for persistent agent memory across restarts) ---
# Create a fine-grained PAT: https://github.com/settings/tokens?type=beta
# Permissions: Contents (R/W), Pull requests (R/W)
GH_TOKEN=

# --- Discord Bot Tokens (one per role) ---
# Create 6 bots at https://discord.com/developers/applications
# See README.md Phase 2 for step-by-step instructions
BOT_TOKEN_PM=
BOT_TOKEN_ARCHITECT=
BOT_TOKEN_DEV=
BOT_TOKEN_QA=
BOT_TOKEN_CLOUDOPS=
BOT_TOKEN_AUDITOR=
