# ============================================================================
# OpenAB Software Team on EKS — with Discord Automation
# Copy to .env and fill in your values:  cp .env.example .env
# ============================================================================

# --- AWS ---
AWS_REGION=us-east-1
CLUSTER_NAME=openab-team
NODE_INSTANCE_TYPE=t3.large
NODE_COUNT=2

# --- Discord Account (for automated bot creation) ---
# Your Discord account credentials — used ONLY in the AgentCore Browser
# session to create bot applications. Never stored or transmitted elsewhere.
DISCORD_EMAIL=
DISCORD_PASSWORD=
DISCORD_SERVER_ID=

# --- Nova Act (for browser automation) ---
# Get your API key at: https://nova.amazon.com/act
NOVA_ACT_API_KEY=

# --- Team Config ---
# Prefix for bot names (e.g., "Team" → Team-Pm, Team-Architect, etc.)
TEAM_PREFIX=Team

# --- Kiro CLI ---
# Get your API key at https://kiro.dev
KIRO_API_KEY=

# --- GitHub (optional — for persistent agent memory) ---
GH_TOKEN=

# ============================================================================
# Below are auto-populated by setup-discord.py — leave blank
# ============================================================================
DISCORD_CHANNEL_ID=
BOT_TOKEN_PM=
BOT_TOKEN_ARCHITECT=
BOT_TOKEN_DEV=
BOT_TOKEN_QA=
BOT_TOKEN_CLOUDOPS=
BOT_TOKEN_AUDITOR=
